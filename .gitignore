/target
**/target
node_modules/
dist/
*.log
.DS_Store
/web/node_modules
/web/dist
/out
/test/tmp/
*.vtk
*.png.tmp
# Ignore local .claude settings but keep committed Skills tracked.
# (Can't re-include a child of an ignored DIR, so ignore .claude contents
#  by glob rather than the directory itself, then negate skills/.)
.claude/*
!.claude/skills/
!.claude/skills/**
.claude/settings.local.json
__pycache__/
